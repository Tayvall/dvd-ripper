# dvd-ripper configuration
# Copy to ~/.config/dvd-ripper/dvd_rip.conf and edit,
# or run setup.sh to generate this automatically.

# ── Device paths ──────────────────────────────────────────────────────────────
# Your optical drive — run `lsblk | grep rom` to find it
DVD_DEVICE="/dev/sr0"

# ── Storage paths ─────────────────────────────────────────────────────────────
# Where finished movies are saved (Kodi library root)
MOVIES_DIR="/media/storage/Movies"

# Temporary rip folder — needs ~10GB free per disc
RIPS_DIR="/media/storage/rips"

# Log files
LOG_DIR="/media/storage/logs"

# ── Tool paths ────────────────────────────────────────────────────────────────
# These are set automatically by install.sh — only change if you built manually
MAKEMKV="/usr/bin/makemkvcon"
HANDBRAKE="/usr/bin/HandBrakeCLI"

# ── Encoding ──────────────────────────────────────────────────────────────────
# HandBrake preset name — run `HandBrakeCLI --preset-list` to see all options
# Recommended options:
#   H.264 MKV 576p25  — standard DVD quality, ~800MB per film
#   H.264 MKV 720p30  — upscaled, slightly larger
#   H.265 MKV 576p25  — smaller files, slower encode
HB_PRESET="H.264 MKV 576p25"

# Minimum title length in seconds — titles shorter than this are skipped
# 1200 = 20 minutes (skips most extras and bonus features)
MIN_TITLE_SECONDS=1200

# ── TMDB API (automatic movie naming) ─────────────────────────────────────────
# Get a free API key at: https://www.themoviedb.org/settings/api
# Leave blank to use manual name entry instead
TMDB_API_KEY=""
TMDB_TOKEN=""
